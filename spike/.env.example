# Copy to .env.local — never commit .env.local
# Blockfrost project keys (read-only, for fetching on-chain credential anchors).
# Generate at https://blockfrost.io — one project per network.
BLOCKFROST_PREPROD_PROJECT_ID=
BLOCKFROST_MAINNET_PROJECT_ID=

# Optional: override the default reference credential
# COURSE_ID=76bab08586cbd53003bfec0e63bc3165fd73afb99cbfa9f4e8157742
# RECIPIENT_ALIAS=lynx
